# Copy to .env and fill in. Values already exported in your shell win over .env.

# Required: token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Optional: restrict the bot to specific chat ids (comma-separated).
# Get your id by messaging @userinfobot. Leave empty to allow anyone who /start's the bot.
ALLOWED_CHAT_IDS=

# Optional tuning (defaults shown)
#SCAN_INTERVAL_MINUTES=15
#ALERT_COOLDOWN_MINUTES=240
#TRIGGER_INTERVAL=15m
#TRIGGER_PERIOD=5d
#MIN_SCORE=4
#STRONG_SCORE=7
#MARKET_HOURS_ONLY=true
#DEFAULT_WATCHLIST=AAPL,MSFT,NVDA,SPY,TSLA
#STATE_FILE=.stock_alert_bot_state.json
